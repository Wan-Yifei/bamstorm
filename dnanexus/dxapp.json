{
  "name": "bamstorm_bench",
  "title": "Bamstorm BAM Reader Benchmark",
  "summary": "Benchmark BAM read throughput: bamstorm vs samtools vs RabbitBAM vs pysam",
  "version": "0.1.0",
  "inputSpec": [
    {
      "name": "bam_file_1",
      "label": "BAM file 1 (bamstorm)",
      "class": "file",
      "patterns": ["*.bam"],
      "help": "BAM file used by bamstorm"
    },
    {
      "name": "bai_file_1",
      "label": "BAM index 1 (bamstorm)",
      "class": "file",
      "patterns": ["*.bai"],
      "help": "Index for bam_file_1"
    },
    {
      "name": "bam_file_2",
      "label": "BAM file 2 (samtools)",
      "class": "file",
      "patterns": ["*.bam"],
      "help": "BAM file used by samtools"
    },
    {
      "name": "bai_file_2",
      "label": "BAM index 2 (samtools)",
      "class": "file",
      "patterns": ["*.bai"],
      "help": "Index for bam_file_2"
    },
    {
      "name": "bam_file_3",
      "label": "BAM file 3 (rabbitbam)",
      "class": "file",
      "patterns": ["*.bam"],
      "help": "BAM file used by rabbitbam"
    },
    {
      "name": "bai_file_3",
      "label": "BAM index 3 (rabbitbam)",
      "class": "file",
      "patterns": ["*.bai"],
      "help": "Index for bam_file_3"
    },
    {
      "name": "bam_file_4",
      "label": "BAM file 4 (pysam)",
      "class": "file",
      "patterns": ["*.bam"],
      "help": "BAM file used by pysam"
    },
    {
      "name": "bai_file_4",
      "label": "BAM index 4 (pysam)",
      "class": "file",
      "patterns": ["*.bai"],
      "help": "Index for bam_file_4"
    },
    {
      "name": "docker_image",
      "label": "Docker image",
      "class": "string",
      "help": "Full Docker image reference, e.g. docker.io/yourname/bamstorm-bench:latest"
    },
    {
      "name": "threads",
      "label": "Thread count",
      "class": "int",
      "help": "Number of threads for this job (one job per thread count)"
    },
    {
      "name": "repeats",
      "label": "Repeats",
      "class": "int",
      "default": 3,
      "optional": true,
      "help": "Timed repetitions per tool; fastest run is reported"
    }
  ],
  "outputSpec": [
    {
      "name": "results_csv",
      "label": "Results CSV",
      "class": "file",
      "patterns": ["*.csv"],
      "help": "Benchmark results: tool, threads, elapsed_s, throughput_mb_s, records"
    },
    {
      "name": "bench_log",
      "label": "Benchmark log",
      "class": "file",
      "patterns": ["*.txt"],
      "help": "Full stdout from the benchmark run"
    }
  ],
  "runSpec": {
    "interpreter": "bash",
    "distribution": "Ubuntu",
    "release": "20.04",
    "version": "0",
    "file": "src/code.sh",
    "systemRequirements": {
      "*": {
        "instanceType": "mem1_ssd1_v2_x16"
      }
    }
  },
  "access": {
    "network": ["*"]
  }
}
